# Install Nerd Fonts on Windows
# Requires PowerShell 5.1+ and admin privileges for system-wide install

$ErrorActionPreference = "Stop"

Write-Host "Installing JetBrainsMono Nerd Font..." -ForegroundColor Green

# Font directory
$fontsDir = if ($env:USERPROFILE) {
    "$env:LOCALAPPDATA\Microsoft\Windows\Fonts"
} else {
    "$env:WINDIR\Fonts"
}

# Ensure directory exists
New-Item -ItemType Directory -Force -Path $fontsDir | Out-Null

# Download URL
$fontUrl = "https://github.com/ryanoasis/nerd-fonts/releases/latest/download/JetBrainsMono.zip"
$tempZip = "$env:TEMP\JetBrainsMono.zip"
$tempDir = "$env:TEMP\JetBrainsMono"

try {
    # Download font
    Write-Host "Downloading font..." -ForegroundColor Yellow
    Invoke-WebRequest -Uri $fontUrl -OutFile $tempZip -UseBasicParsing

    # Extract
    Write-Host "Extracting font..." -ForegroundColor Yellow
    Expand-Archive -Path $tempZip -DestinationPath $tempDir -Force

    # Install fonts
    Write-Host "Installing fonts..." -ForegroundColor Yellow
    $fonts = Get-ChildItem -Path $tempDir -Include "*.ttf", "*.otf" -Recurse

    foreach ($font in $fonts) {
        $fontName = $font.Name
        $destPath = Join-Path $fontsDir $fontName

        # Copy font file
        Copy-Item -Path $font.FullName -Destination $destPath -Force

        # Register font in registry (user scope)
        $regPath = "HKCU:\SOFTWARE\Microsoft\Windows NT\CurrentVersion\Fonts"
        $fontRegistryName = [System.IO.Path]::GetFileNameWithoutExtension($fontName)
        New-ItemProperty -Path $regPath -Name $fontRegistryName -Value $destPath -PropertyType String -Force | Out-Null
    }

    Write-Host "JetBrainsMono Nerd Font installed successfully" -ForegroundColor Green
    Write-Host "Note: You may need to restart applications to see the new font" -ForegroundColor Yellow

} catch {
    Write-Host "Error installing fonts: $_" -ForegroundColor Red
    exit 1
} finally {
    # Clean up
    if (Test-Path $tempZip) { Remove-Item $tempZip -Force }
    if (Test-Path $tempDir) { Remove-Item $tempDir -Recurse -Force }
}
