{{- if eq .chezmoi.os "windows" -}}
# Install 1Password CLI on Windows
$ErrorActionPreference = "Stop"

if (Get-Command op -ErrorAction SilentlyContinue) {
    Write-Host "1Password CLI is already installed."
    exit 0
}

Write-Host "Installing 1Password CLI..."

if (Get-Command winget -ErrorAction SilentlyContinue) {
    winget install --id AgileBits.1Password.CLI --accept-source-agreements --accept-package-agreements --silent
} elseif (Get-Command scoop -ErrorAction SilentlyContinue) {
    scoop install op
} elseif (Get-Command choco -ErrorAction SilentlyContinue) {
    choco install op -y
} else {
    Write-Error "No supported package manager found (winget/scoop/choco). Install 1Password CLI manually from https://developer.1password.com/docs/cli/get-started/"
    exit 1
}

Write-Host "1Password CLI installed successfully."
{{ end -}}
