{{- if eq .chezmoi.os "linux" -}}
#!/usr/bin/env bash
# Install Neovim on Linux (Debian/Ubuntu, Fedora/RHEL, Arch, Alpine) and WSL
set -euo pipefail

if command -v nvim &>/dev/null; then
    echo "Neovim is already installed."
    exit 0
fi

echo "Installing Neovim..."
if command -v pacman &>/dev/null; then
    sudo pacman -S --noconfirm --needed neovim
elif command -v apt-get &>/dev/null; then
    # Use the unstable PPA for a recent Neovim version on Debian/Ubuntu
    { sudo apt-get update -qq || true; } && sudo apt-get install -y -qq software-properties-common
    sudo add-apt-repository -y ppa:neovim-ppa/unstable
    { sudo apt-get update -qq || true; } && sudo apt-get install -y -qq neovim
elif command -v dnf &>/dev/null; then
    sudo dnf install -y -q neovim
elif command -v yum &>/dev/null; then
    sudo yum install -y -q neovim
elif command -v apk &>/dev/null; then
    sudo apk add --no-cache neovim
elif command -v zypper &>/dev/null; then
    sudo zypper install -y neovim
else
    echo "Error: No supported package manager found. Install Neovim manually."
    exit 1
fi

echo "Neovim installed successfully."
{{ end -}}
