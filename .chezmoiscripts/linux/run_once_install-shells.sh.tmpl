{{- if eq .chezmoi.os "linux" -}}
#!/usr/bin/env bash
# Install bash, zsh, and fish shells on Linux (Debian/Ubuntu, Fedora/RHEL, Arch, Alpine) and WSL
set -euo pipefail

install_if_missing() {
    local cmd="$1"
    shift
    if command -v "$cmd" &>/dev/null; then
        echo "$cmd is already installed."
        return 0
    fi
    echo "Installing $cmd..."
    "$@"
}

if command -v apt-get &>/dev/null; then
    sudo apt-get update -qq
    install_if_missing bash sudo apt-get install -y -qq bash
    install_if_missing zsh  sudo apt-get install -y -qq zsh
    install_if_missing fish sudo apt-get install -y -qq fish || {
        # fish may need PPA on older Ubuntu
        sudo apt-get install -y -qq software-properties-common
        sudo add-apt-repository -y ppa:fish-shell/release-3
        sudo apt-get update -qq
        sudo apt-get install -y -qq fish
    }
elif command -v dnf &>/dev/null; then
    install_if_missing bash sudo dnf install -y -q bash
    install_if_missing zsh  sudo dnf install -y -q zsh
    install_if_missing fish sudo dnf install -y -q fish
elif command -v yum &>/dev/null; then
    install_if_missing bash sudo yum install -y -q bash
    install_if_missing zsh  sudo yum install -y -q zsh
    install_if_missing fish sudo yum install -y -q fish
elif command -v pacman &>/dev/null; then
    install_if_missing bash sudo pacman -S --noconfirm --needed bash
    install_if_missing zsh  sudo pacman -S --noconfirm --needed zsh
    install_if_missing fish sudo pacman -S --noconfirm --needed fish
elif command -v apk &>/dev/null; then
    install_if_missing bash sudo apk add --quiet bash
    install_if_missing zsh  sudo apk add --quiet zsh
    install_if_missing fish sudo apk add --quiet fish
else
    echo "Error: No supported package manager found. Install bash, zsh, and fish manually."
    exit 1
fi

echo "Shells installed successfully."
{{ end -}}
