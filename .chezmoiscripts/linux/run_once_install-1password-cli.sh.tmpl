{{- if eq .chezmoi.os "linux" -}}
#!/usr/bin/env bash
# Install 1Password CLI on Linux (Debian/Ubuntu, Fedora/RHEL, Arch, Alpine)
set -euo pipefail

if command -v op &>/dev/null; then
    echo "1Password CLI is already installed."
    exit 0
fi

echo "Installing 1Password CLI..."

add_rpm_repo() {
    local repo_file="$1"
    sudo rpm --import https://downloads.1password.com/linux/keys/1password.asc
    sudo sh -c "echo -e '[1password]\nname=1Password Stable Channel\nbaseurl=https://downloads.1password.com/linux/rpm/stable/\$basearch\nenabled=1\ngpgcheck=1\nrepo_gpgcheck=1\ngpgkey=https://downloads.1password.com/linux/keys/1password.asc' > $repo_file"
}

if command -v apt-get &>/dev/null; then
    # Debian/Ubuntu: add the official 1Password APT repo
    sudo mkdir -p /usr/share/keyrings
    curl -sS https://downloads.1password.com/linux/keys/1password.asc \
        | sudo gpg --dearmor --output /usr/share/keyrings/1password-archive-keyring.gpg
    echo "deb [arch=$(dpkg --print-architecture) signed-by=/usr/share/keyrings/1password-archive-keyring.gpg] https://downloads.1password.com/linux/debian/$(dpkg --print-architecture) stable main" \
        | sudo tee /etc/apt/sources.list.d/1password.list >/dev/null
    sudo apt-get update -qq
    sudo apt-get install -y -qq 1password-cli
elif command -v dnf &>/dev/null; then
    # Fedora/RHEL: add the official 1Password RPM repo
    add_rpm_repo /etc/yum.repos.d/1password.repo
    sudo dnf install -y -q 1password-cli
elif command -v yum &>/dev/null; then
    add_rpm_repo /etc/yum.repos.d/1password.repo
    sudo yum install -y -q 1password-cli
elif command -v pacman &>/dev/null; then
    sudo pacman -S --noconfirm --needed 1password-cli
elif command -v apk &>/dev/null; then
    # Alpine: install from the community repo
    sudo apk add --no-cache 1password-cli
elif command -v zypper &>/dev/null; then
    add_rpm_repo /etc/zypp/repos.d/1password.repo
    sudo zypper install -y 1password-cli
else
    echo "Error: No supported package manager found. Install 1Password CLI manually from https://developer.1password.com/docs/cli/get-started/"
    exit 1
fi

echo "1Password CLI installed successfully."
{{ end -}}
