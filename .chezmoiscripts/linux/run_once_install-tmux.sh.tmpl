{{- if eq .chezmoi.os "linux" -}}
#!/usr/bin/env bash
# Install tmux on Linux (Debian/Ubuntu, Fedora/RHEL, Arch, Alpine) and WSL
set -euo pipefail

if command -v tmux &>/dev/null; then
    echo "tmux is already installed."
    exit 0
fi

echo "Installing tmux..."
if command -v apt-get &>/dev/null; then
    { sudo apt-get update -qq || true; } && sudo apt-get install -y -qq tmux
elif command -v dnf &>/dev/null; then
    sudo dnf install -y -q tmux
elif command -v yum &>/dev/null; then
    sudo yum install -y -q tmux
elif command -v pacman &>/dev/null; then
    sudo pacman -S --noconfirm --needed tmux
elif command -v apk &>/dev/null; then
    sudo apk add --no-cache tmux
elif command -v zypper &>/dev/null; then
    sudo zypper install -y tmux
else
    echo "Error: No supported package manager found. Install tmux manually."
    exit 1
fi

echo "tmux installed successfully."
{{ end -}}
