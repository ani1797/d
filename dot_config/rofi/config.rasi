/* rofi configuration */
configuration {
    modi: "drun,run,window";
    show-icons: true;
    icon-theme: "Adwaita";
    font: "JetBrainsMono Nerd Font 12";
    display-drun: " Apps";
    display-run: " Run";
    display-window: " Windows";
    drun-display-format: "{name}";
    terminal: "kitty";
    case-sensitive: false;
    cycle: true;
    sidebar-mode: false;
    matching: "fuzzy";
    sort: true;
    sorting-method: "fzf";
}

@theme "tokyo-night"
