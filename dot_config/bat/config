# bat configuration
# https://github.com/sharkdp/bat

# Theme (Tokyo Night)
--theme="tokyonight_night"

# Show line numbers and git changes, no grid
--style="numbers,changes,header"

# Use italic for comments
--italic-text=always

# Paging: use less with options matching git
--pager="less -FRX"

# Map plain text extensions for syntax highlighting
--map-syntax "*.conf:INI"
--map-syntax "*.env:Bourne Again Shell (bash)"
--map-syntax ".gitignore:Git Ignore"
--map-syntax "*.toml.tmpl:TOML"
