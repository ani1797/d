#!/usr/bin/env bash
# test - Test dotfiles installation in a Docker container
#
# Usage:
#   ./test                  # default: ubuntu
#   ./test ubuntu           # Ubuntu (Debian-based)
#   ./test debian           # Debian
#   ./test fedora           # Fedora (dnf)
#   ./test archlinux        # Arch Linux (pacman)
#   ./test alpine           # Alpine Linux (apk)
#
# Mounts the dotfiles repo into the container, runs install, and drops into zsh.
#
set -euo pipefail

PLATFORM="${1:-ubuntu}"

SUPPORTED_PLATFORMS=(ubuntu debian fedora archlinux alpine)

# Capitalize first letter for Dockerfile name
DOCKERFILE_NAME="$(echo "${PLATFORM:0:1}" | tr '[:lower:]' '[:upper:]')${PLATFORM:1}"

SCRIPT_DIR="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)"
DOCKERFILE="$SCRIPT_DIR/.devcontainer/images/${DOCKERFILE_NAME}.dockerfile"

if [[ ! -f "$DOCKERFILE" ]]; then
    echo "Error: Unknown platform '$PLATFORM'"
    echo ""
    echo "Supported platforms: ${SUPPORTED_PLATFORMS[*]}"
    exit 1
fi

IMAGE_TAG="dotfiles-test:${PLATFORM}"

# Detect if we have a TTY for interactive mode
DOCKER_FLAGS="--rm"
if [[ -t 0 && -t 1 ]]; then
    DOCKER_FLAGS="--rm -it"
fi

echo "Building test image for $PLATFORM..."
docker build -q -t "$IMAGE_TAG" -f "$DOCKERFILE" "$SCRIPT_DIR" > /dev/null

echo "Testing on $PLATFORM ($IMAGE_TAG)..."

docker run $DOCKER_FLAGS \
    -v "$SCRIPT_DIR:/dotfiles:ro" \
    -e GIT_AUTHOR_NAME="Test User" \
    -e GIT_AUTHOR_EMAIL="test@example.com" \
    -e TERM="${TERM:-dumb}" \
    "$IMAGE_TAG" \
    sh -c "
        set -e
        echo '── Copying dotfiles (avoid modifying mount) ──'
        cp -r /dotfiles /tmp/dotfiles

        echo '── Running install script ──'
        cd /tmp/dotfiles
        bash ./install

        echo ''
        echo '── Installation complete ──'
        if [ -t 0 ]; then
            echo 'Launching fish...'
            exec fish -l
        else
            echo 'Non-interactive mode — verifying fish is available.'
            fish --version
            echo '=== TEST PASSED ==='
        fi
    "
