{{- $name := promptStringOnce . "name" "Your full name" -}}
{{- $email := promptStringOnce . "email" "Your email address" -}}
{{- $hyprland := promptBoolOnce . "hyprland" "Install Hyprland desktop configs? (Arch Linux only)" -}}

[data]
    name = {{ $name | quote }}
    email = {{ $email | quote }}
    hyprland = {{ $hyprland }}
